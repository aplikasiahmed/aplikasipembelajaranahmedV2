# Google Sheets Integration
# ID of the Google Sheets Database Spreadsheet (obtained from its URL: docs.google.com/spreadsheets/d/[SPREADSHEET_ID]/...)
VITE_GOOGLE_SPREADSHEET_ID=

# Google Apps Script Web App URL for direct background synchronization (begins with https://script.google.com/)
VITE_GOOGLE_APPS_SCRIPT_URL=

# Google OAuth Client ID for direct Google Sheets connection (from Google Cloud Credentials Console)
VITE_GOOGLE_CLIENT_ID=
